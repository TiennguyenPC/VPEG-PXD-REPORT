{
  "name": "epc-solar-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "gas:login": "node scripts/gas-deploy.mjs login",
    "gas:push": "node scripts/gas-deploy.mjs push",
    "gas:deploy": "node scripts/gas-deploy.mjs deploy",
    "gas:sync": "node scripts/gas-deploy.mjs sync",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:icons": "node scripts/generate-android-icons.mjs",
    "android:apk": "npm run android:icons && cd android && gradlew.bat assembleDebug && node -e \"const fs=require('fs'),p=require('path');const src=p.join('app','build','outputs','apk','debug','app-debug.apk');const dir=p.join('..','releases');fs.mkdirSync(dir,{recursive:true});fs.copyFileSync(src,p.join(dir,'VPEG-PXD.apk'));console.log('OK: releases/VPEG-PXD.apk');\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "framer-motion": "^12.39.0",
    "groq-sdk": "^1.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "^3.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "xlsx": "^0.18.5"
  }
}
